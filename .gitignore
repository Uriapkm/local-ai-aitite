```gitignore
# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Local environment variables
.env.local

# Temporary and backup files
*.tmp
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Logs
*.log

# Coverage reports
coverage/
htmlcov/
.coverage

# MyPy cache
.mypy_cache/

# Pytest cache
.pytest_cache/

# Original rules preserved
*.log
```