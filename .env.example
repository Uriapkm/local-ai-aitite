# ============================================
# CONFIGURACIÓN - Abuelo IA Assistant
# ============================================
# Copia este archivo a .env y ajusta los valores
# Las variables de entorno tienen prioridad sobre settings.yaml
# ============================================

# --------------------------------------------
# HARDWARE - Arduino
# --------------------------------------------
# CRÍTICO: El puerto puede ser /dev/ttyUSB0, /dev/ttyACM0, o variar según tu sistema
# Para descubrir el puerto: ls /dev/ttyUSB* /dev/ttyACM*
ARDUINO_PORT=/dev/ttyUSB0
ARDUINO_BAUD_RATE=9600
ARDUINO_BUTTON_PIN=2
ARDUINO_IR_LED_PIN=3

# --------------------------------------------
# AUDIO - Whisper STT y Piper TTS
# --------------------------------------------
# Modelos disponibles: tiny, base, small, medium, large
# tiny/base = rápido pero menos preciso | large = preciso pero lento
WHISPER_MODEL=small
WHISPER_DEVICE=auto
WHISPER_LANGUAGE=es

# Voces Piper disponibles: https://github.com/rhasspy/piper/blob/master/VOICES.md
PIPER_VOICE=es_ES-carlfm-medium
PIPER_DATA_DIR=./data/piper_voices

AUDIO_SAMPLE_RATE=16000
AUDIO_SILENCE_THRESHOLD=0.5

# --------------------------------------------
# LLM - Gemma 4 vía Ollama
# --------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:4b-instruct-q4_K_M
OLLAMA_CONTEXT_LENGTH=8192
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=512

# --------------------------------------------
# VISIÓN - Cámara web
# --------------------------------------------
VISION_ENABLED=true
CAMERA_INDEX=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAPTURE_DELAY=0.5

# --------------------------------------------
# TV - Configuración específica
# --------------------------------------------
TV_BRAND=Samsung
TV_PC_HDMI_PORT=HDMI1
TV_TV_HDMI_PORT=HDMI2
TV_MUTE_ON_PRESS=true
TV_UNMUTE_ON_RELEASE=true
TV_VOLUME_RESTORE_DELAY=2

# --------------------------------------------
# YOUTUBE / NAVEGADOR
# --------------------------------------------
# CRÍTICO PARA BAZZITE: brave, chrome, o firefox
# Si usas Flatpak, necesitas permisos especiales (ver docs)
BROWSER=brave
BROWSER_KIOSK_MODE=false
YOUTUBE_DEFAULT_QUALITY=1080p
YOUTUBE_SAVE_HISTORY=true
YOUTUBE_HISTORY_DB=./data/youtube_history.db

# --------------------------------------------
# SISTEMA DETECTA AUTOMÁTICAMENTE
# --------------------------------------------
# PyAutoGUI backend para Linux/Wayland
# Opciones: auto, x11, wayland
# Deja en 'auto' para detección automática
PYAUTOGUI_BACKEND=auto

# --------------------------------------------
# MEMORIA - Historial y preferencias
# --------------------------------------------
MEMORY_ENABLED=true
MEMORY_DB_PATH=./data/abuelo_memory.db
MAX_CONVERSATION_HISTORY=20
SAVE_PREFERENCES=true
AUTO_SUGGEST_INTERVAL=3600

# --------------------------------------------
# INTERFAZ - Feedback visual
# --------------------------------------------
SHOW_SUBTITLES=true
SUBTITLE_FONT_SIZE=48
SUBTITLE_POSITION=bottom
SHOW_STATUS_INDICATOR=true
INTERFACE_THEME=dark

# --------------------------------------------
# SISTEMA - Logs y debug
# --------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/abuelo_agent.log
ENABLE_DEBUG_MODE=false
AUTO_RESTART_ON_ERROR=true

# --------------------------------------------
# PERMISOS FLATPAK (BAZZITE)
# --------------------------------------------
# CRÍTICO: Si usas navegador Flatpak, necesita estos permisos
# El script install.sh debería configurarlos automáticamente
# Valores: true para habilitar, false para deshabilitar
FLATPAK_BROWSER=com.brave.Browser
FLATPAK_ENABLE_WAYLAND=true
FLATPAK_ENABLE_X11=true
FLATPAK_ENABLE_DEVICES=all
